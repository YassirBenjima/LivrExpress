{% extends 'base_dashboard.html.twig' %}

{% block title %}Affiliate - LivrExpress{% endblock %}

{% block body %}
<main class="grow pt-5 dashboard-content-shift" id="content" role="content">
  <div class="kt-container-fixed" id="contentContainer"></div>

  <div class="kt-container-fixed">
    <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
      <div class="flex flex-col justify-center gap-2">
        <h1 class="text-xl font-medium leading-none text-mono">Affiliate</h1>
        <span class="text-sm text-secondary-foreground">Parrainez des clients et gagnez des commissions sur chaque livraison.</span>
      </div>
    </div>
  </div>

  <div class="kt-container-fixed mb-5">
    <div class="grid grid-cols-3 gap-5">
      <div class="kt-card">
        <div class="kt-card-content p-5 flex items-center gap-4">
          <div class="size-[50px] shrink-0 rounded-xl bg-violet-500/10 flex items-center justify-center">
            <i class="ki-filled ki-gift text-xl text-violet-600"></i>
          </div>
          <div class="flex flex-col">
            <div class="flex items-center gap-1.5">
              <span class="text-2xl font-semibold text-mono">{{ next_payment|number_format(0, ',', ' ') }} DH</span>
              <span class="inline-flex items-center" data-kt-tooltip="true" data-kt-tooltip-placement="top">
                <i class="ki-filled ki-information-2 text-sm text-secondary-foreground cursor-help"></i>
                <span class="kt-tooltip" data-kt-tooltip-content="true">
                  Montant de votre prochain virement mensuel des commissions d'affiliation.
                </span>
              </span>
            </div>
            <span class="text-xs text-secondary-foreground font-medium">Prochain paiement</span>
          </div>
        </div>
      </div>

      <div class="kt-card">
        <div class="kt-card-content p-5 flex items-center gap-4">
          <div class="size-[50px] shrink-0 rounded-xl bg-primary/10 flex items-center justify-center">
            <i class="ki-filled ki-people text-xl text-primary"></i>
          </div>
          <div class="flex flex-col">
            <span class="text-2xl font-semibold text-mono">{{ total_referred }}</span>
            <span class="text-xs text-secondary-foreground font-medium">Total référencé</span>
          </div>
        </div>
      </div>

      <div class="kt-card">
        <div class="kt-card-content p-5 flex items-center gap-4">
          <div class="size-[50px] shrink-0 rounded-xl bg-success/10 flex items-center justify-center">
            <i class="ki-filled ki-dollar text-xl text-success"></i>
          </div>
          <div class="flex flex-col">
            <span class="text-2xl font-semibold text-mono">{{ total_earnings|number_format(0, ',', ' ') }} DH</span>
            <span class="text-xs text-secondary-foreground font-medium">Total des gains reçus</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="kt-container-fixed mb-5">
    <div class="kt-card">
      <div class="kt-card-header">
        <h3 class="kt-card-title text-sm">Vos liens d'affiliation</h3>
      </div>
      <div class="kt-card-content flex flex-col gap-5">
        <p class="text-sm text-secondary-foreground leading-relaxed">
          Les liens d'affiliation sont des URL uniques qui vous permettent de gagner une commission en référant des clients.
          Partagez votre lien long ou court avec d'autres personnes et gagnez un pourcentage.
        </p>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          <div class="border border-border rounded-xl p-4 flex flex-col gap-3">
            <div class="flex items-center justify-between gap-2">
              <span class="text-sm font-medium text-foreground">Lien complet</span>
              <span class="kt-badge kt-badge-primary kt-badge-outline rounded-[30px] text-xs">Full</span>
            </div>
            <div class="kt-input bg-muted/30">
              <input class="text-xs truncate" id="affiliate_full_link" readonly type="text" value="{{ full_link }}"/>
            </div>
            <button class="kt-btn kt-btn-outline kt-btn-primary kt-btn-sm w-fit affiliate-copy-btn" data-copy-target="affiliate_full_link" type="button">
              <i class="ki-filled ki-copy"></i>
              Copier
            </button>
          </div>
          <div class="border border-border rounded-xl p-4 flex flex-col gap-3">
            <div class="flex items-center justify-between gap-2">
              <span class="text-sm font-medium text-foreground">Lien court</span>
              <span class="kt-badge kt-badge-success kt-badge-outline rounded-[30px] text-xs">Short</span>
            </div>
            <div class="kt-input bg-muted/30">
              <input class="text-xs truncate" id="affiliate_short_link" readonly type="text" value="{{ short_link }}"/>
            </div>
            <button class="kt-btn kt-btn-outline kt-btn-primary kt-btn-sm w-fit affiliate-copy-btn" data-copy-target="affiliate_short_link" type="button">
              <i class="ki-filled ki-copy"></i>
              Copier
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="kt-container-fixed pb-5">
    <div class="kt-card">
      <div class="kt-card-content p-5 lg:p-7.5 flex flex-col gap-5">
        <div class="flex items-start gap-3">
          <div class="size-[44px] shrink-0 rounded-xl bg-violet-500/10 flex items-center justify-center">
            <i class="ki-filled ki-percentage text-xl text-violet-600"></i>
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-base font-semibold text-foreground">Gagnez 3% sur chaque livraison</h3>
            <p class="text-sm text-secondary-foreground leading-relaxed">
              Chaque colis livré par vos références vous rapporte 3% des frais de livraison.
              Vous pouvez utiliser cet argent pour livrer ou le recevoir chaque mois en paiement.
            </p>
          </div>
        </div>

        <div class="border-t border-border pt-5">
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <h4 class="text-sm font-semibold text-foreground">Comment ça marche ?</h4>
            <span class="kt-badge kt-badge-success kt-badge-outline rounded-[30px] text-xs">
              <span class="kt-badge-dot size-1.5"></span>
              Facile et Rapide
            </span>
          </div>
          <ol class="flex flex-col gap-4">
            <li class="flex items-start gap-3">
              <span class="flex shrink-0 size-7 items-center justify-center rounded-full bg-primary text-primary-foreground text-xs font-semibold">1</span>
              <span class="text-sm text-secondary-foreground pt-1">Partagez votre lien de parrainage avec vos amis, collègues ou sur les réseaux sociaux.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex shrink-0 size-7 items-center justify-center rounded-full bg-primary text-primary-foreground text-xs font-semibold">2</span>
              <span class="text-sm text-secondary-foreground pt-1">Dès qu'ils livrent, vous gagnez plus de 3% sur chaque livraison.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex shrink-0 size-7 items-center justify-center rounded-full bg-primary text-primary-foreground text-xs font-semibold">3</span>
              <span class="text-sm text-secondary-foreground pt-1">Utilisez cet argent pour vos propres envois ou recevez-le chaque mois en paiement.</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</main>
{% endblock %}

{% block javascripts %}
  <script src="{{ asset('assets/js/affiliate.js') }}"></script>
{% endblock %}
