{% extends 'base_dashboard.html.twig' %}

{% block title %}Mon Profil - LivrExpress{% endblock %}

{% block body %}
    {% set initials = '' %}
    {% set avatarColor = '#007bff' %}
    {% set profileAvatarUrl = profileAvatarFilename is defined and profileAvatarFilename ? asset('uploads/avatars/' ~ profileAvatarFilename) : null %}
    {% if app.user and app.user.fullName %}
        {% set names = app.user.fullName|trim|split(' ') %}
        {% set initials = names|first|slice(0, 1)|upper %}
        {% if names|length > 1 %}
            {% set initials = initials ~ names|last|slice(0, 1)|upper %}
        {% endif %}
        {% set colors = ['#EA4335', '#4285F4', '#FBBC04', '#34A853', '#A142F4', '#F439A0', '#24C1E0', '#FF6D01', '#6D4C41', '#546E7A'] %}
        {% set colorIndex = (app.user.fullName|length) % (colors|length) %}
        {% set avatarColor = colors[colorIndex] %}
    {% endif %}
    <!-- Content -->
    <main class="grow pt-5 profile-content-shift" id="content" role="content">

        <div class="flex items-center flex-wrap md:flex-nowrap lg:items-end justify-between border-b border-b-border gap-3 lg:gap-6 mb-3 lg:mb-5">
            <!-- Container -->
            <div class="kt-container-fixed" id="hero_container">
                <div class="grid">
                    <div class="kt-scrollable-x-auto">
                        <div class="kt-menu gap-3" data-kt-menu="true">
                            <div class="kt-menu-item border-b-2 border-b-transparent kt-menu-item-active:border-b-primary kt-menu-item-here:border-b-primary here">
                                <a class="kt-menu-link gap-1.5 pb-2 lg:pb-4 px-2" href="{{ path('app_profile') }}">
                                    <span class="kt-menu-title text-nowrap text-sm text-secondary-foreground kt-menu-item-active:text-primary kt-menu-item-active:font-medium kt-menu-item-here:text-primary kt-menu-item-here:font-medium kt-menu-item-show:text-primary kt-menu-link-hover:text-primary">
                                        Général
                                    </span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- End of Container -->
        </div>
        <!-- Container -->
        <div class="kt-container-fixed">
            <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
                <div class="flex flex-col justify-center gap-2">
                    <h1 class="text-xl font-medium leading-none text-mono">
                        Mon Profil
                    </h1>
                    <div class="flex items-center gap-2 text-sm font-normal text-secondary-foreground">
                        Gérez vos informations et paramètres de compte
                    </div>
                </div>
                <div class="flex flex-col items-end gap-2.5">
                    <div class="flex items-center gap-2.5">
                    <button class="kt-btn kt-btn-outline" id="profile-cancel-btn" type="button">
                        Cancel
                    </button>
                    <button class="kt-btn kt-btn-primary" id="profile-save-btn" type="button">
                        Enregistrer
                    </button>
                    </div>
                </div>
            </div>
        </div>
        <!-- End of Container -->
        <!-- Container -->
        <div class="kt-container-fixed">
            <!-- begin: grid -->
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-5 lg:gap-7.5">
                <div class="col-span-1">
                    <div class="grid gap-5 lg:gap-7.5">
                        <!-- Personal Info Card -->
                        <div class="kt-card min-w-full">
                            <div class="kt-card-header">
                                <h3 class="kt-card-title">Informations Personnelles</h3>
                            </div>
                            <div class="kt-card-table pb-3" style="overflow: visible;">
                                <table class="kt-table align-middle text-sm text-muted-foreground">
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Photo</td>
                                        <td class="py-2 text-secondary-foreground font-normal text-sm">Image JPEG, PNG 150x150px</td>
                                        <td class="py-2 text-center">
                                            <form action="{{ path('app_profile_avatar_update') }}" class="flex justify-center items-center" enctype="multipart/form-data" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_avatar') }}"/>
                                                <div class="kt-image-input size-16 {{ profileAvatarUrl ? '' : 'empty' }}" data-kt-image-input="true">
                                                    <input accept=".png, .jpg, .jpeg" name="avatar" type="file"/>
                                                    <input name="avatar_remove" type="hidden"/>
                                                    <button class="kt-image-input-remove" data-kt-image-input-remove="true" data-kt-tooltip="true" data-kt-tooltip-placement="right" data-kt-tooltip-trigger="hover" type="button">
                                                        <i class="ki-filled ki-cross"></i>
                                                        <span class="kt-tooltip" data-kt-tooltip-content="true">Cliquer pour supprimer ou annuler</span>
                                                    </button>
                                                    <div class="kt-image-input-placeholder border-2 border-input kt-image-input-empty:border-input" data-kt-image-input-placeholder="true">
                                                        {% if profileAvatarUrl %}
                                                            <div class="kt-image-input-preview" data-kt-image-input-preview="true" style="background-image:url('{{ profileAvatarUrl }}');"></div>
                                                        {% else %}
                                                            <div class="kt-image-input-preview inline-flex items-center justify-center ring-1 ring-background shadow-sm text-white font-semibold text-lg" data-kt-image-input-preview="true" style="background-color: {{ avatarColor }};">
                                                                <span class="avatar-initials-text">{{ initials ?: 'U' }}</span>
                                                            </div>
                                                        {% endif %}
                                                        <div class="flex items-center justify-center cursor-pointer h-5 left-0 right-0 bottom-0 bg-black/25 absolute">
                                                            <svg class="fill-border opacity-80" height="12" viewbox="0 0 14 12" width="14" xmlns="http://www.w3.org/2000/svg">
                                                                <path d="M11.6665 2.64585H11.2232C11.0873 2.64749 10.9538 2.61053 10.8382 2.53928C10.7225 2.46803 10.6295 2.36541 10.5698 2.24335L10.0448 1.19918C9.91266 0.931853 9.70808 0.707007 9.45438 0.550249C9.20068 0.393491 8.90806 0.311121 8.60984 0.312517H5.38984C5.09162 0.311121 4.799 0.393491 4.5453 0.550249C4.2916 0.707007 4.08701 0.931853 3.95484 1.19918L3.42984 2.24335C3.37021 2.36541 3.27716 2.46803 3.1615 2.53928C3.04584 2.61053 2.91234 2.64749 2.7765 2.64585H2.33317C1.90772 2.64585 1.49969 2.81486 1.19885 3.1157C0.898014 3.41654 0.729004 3.82457 0.729004 4.25002V10.0834C0.729004 10.5088 0.898014 10.9168 1.19885 11.2177C1.49969 11.5185 1.90772 11.6875 2.33317 11.6875H11.6665C12.092 11.6875 12.5 11.5185 12.8008 11.2177C13.1017 10.9168 13.2707 10.5088 13.2707 10.0834V4.25002C13.2707 3.82457 13.1017 3.41654 12.8008 3.1157C12.5 2.81486 12.092 2.64585 11.6665 2.64585ZM6.99984 9.64585C6.39413 9.64585 5.80203 9.46624 5.2984 9.12973C4.79478 8.79321 4.40225 8.31492 4.17046 7.75532C3.93866 7.19572 3.87802 6.57995 3.99618 5.98589C4.11435 5.39182 4.40602 4.84613 4.83432 4.41784C5.26262 3.98954 5.80831 3.69786 6.40237 3.5797C6.99644 3.46153 7.61221 3.52218 8.1718 3.75397C8.7314 3.98576 9.2097 4.37829 9.54621 4.88192C9.88272 5.38554 10.0623 5.97765 10.0623 6.58335C10.0608 7.3951 9.73765 8.17317 9.16365 8.74716C8.58965 9.32116 7.81159 9.64431 7 9.64585Z"></path>
                                                                <path d="M7 8.77087C8.20812 8.77087 9.1875 7.7915 9.1875 6.58337C9.1875 5.37525 8.20812 4.39587 7 4.39587C5.79188 4.39587 4.8125 5.37525 4.8125 6.58337C4.8125 7.7915 5.79188 8.77087 7 8.77087Z"></path>
                                                            </svg>
                                                        </div>
                                                    </div>
                                                </div>
                                            </form>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Nom complet *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-full-name-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="full_name"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" required type="text" value="{{ app.user ? app.user.fullName : '' }}" data-db-value="{{ app.user.fullName ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-full-name-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Numéro de téléphone personnel *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-personal-phone-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="personal_phone"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" required type="text" value="{{ app.user ? app.user.businessPhone : '' }}" data-db-value="{{ app.user.businessPhone ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-personal-phone-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Adresse email *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-email-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="email"/>
                                                <input class="kt-input h-8 text-sm" maxlength="180" name="value" required type="email" value="{{ app.user ? app.user.email : '' }}" data-db-value="{{ app.user.email ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-email-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Ville *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-city-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="city"/>
                                                <select class="kt-select" name="value" required data-kt-select="true" data-kt-select-dropdown-parent="body" data-kt-select-enable-search="true" data-kt-select-placeholder="Choisir une ville" data-kt-select-search-placeholder="Rechercher une ville..." data-db-value="{{ app.user.city ?? '' }}">
                                                    <option value="" disabled {{ not (app.user and app.user.city) ? 'selected' : '' }}>Choisir une ville</option>
                                                    {% for city in cities %}
                                                        <option value="{{ city.name }}" {{ app.user and app.user.city == city.name ? 'selected' : '' }}>
                                                            {{ city.name }}
                                                        </option>
                                                    {% endfor %}
                                                </select>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-city-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Adresse *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-address-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="address"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" placeholder="Aucune adresse definie" type="text" value="{{ app.user and app.user.address ? app.user.address : '' }}" data-db-value="{{ app.user.address ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-address-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <!-- Delivery Preferences Card -->
                        <div class="kt-card min-w-full">
                            <div class="kt-card-header">
                                <h3 class="kt-card-title">Préférences de Livraison</h3>
                            </div>
                            <div class="kt-card-table pb-3" style="overflow: visible;">
                                <table class="kt-table align-middle text-sm text-muted-foreground">
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Votre message sur étiquette</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-label-message-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="label_message"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" placeholder="Ajouter un message" type="text" value="{{ app.user and app.user.labelMessage ? app.user.labelMessage : '' }}" data-db-value="{{ app.user.labelMessage ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-label-message-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Colis</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-package-option-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="package_option"/>
                                                <select class="kt-select" name="value" required data-kt-select="true" data-kt-select-dropdown-parent="body" data-kt-select-enable-search="true" data-kt-select-placeholder="Choisir une option colis" data-kt-select-search-placeholder="Rechercher une option..." data-db-value="{{ app.user.packageOption ?? '' }}">
                                                    <option value="Ne pas ouvrir le colis" {{ not (app.user and app.user.packageOption) or app.user.packageOption == 'Ne pas ouvrir le colis' ? 'selected' : '' }}>Ne pas ouvrir le colis</option>
                                                    <option value="Ouvrir le colis" {{ app.user and app.user.packageOption == 'Ouvrir le colis' ? 'selected' : '' }}>Ouvrir le colis</option>
                                                </select>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-package-option-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="kt-card min-w-full">
                            <div class="kt-card-header">
                                <h3 class="kt-card-title">Mot de passe</h3>
                                <button class="kt-btn kt-btn-primary" form="profile-password-form" id="profile-password-save-btn" type="submit">Mettre a jour le mot de passe</button>
                            </div>
                            <div class="kt-card-table pb-3">
                                <form action="{{ path('app_profile_password_update') }}" id="profile-password-form" method="post">
                                    <input name="_token" type="hidden" value="{{ csrf_token('profile_password') }}"/>
                                    <table class="kt-table align-middle text-sm text-muted-foreground">
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Ancien mot de passe</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <input class="kt-input h-8 text-sm" name="current_password" placeholder="Ancien mot de passe" required type="password"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Nouveau mot de passe</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <input class="kt-input h-8 text-sm" minlength="8" name="new_password" placeholder="Nouveau mot de passe" required type="password"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Re-taper le nouveau mot de passe</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <input class="kt-input h-8 text-sm" minlength="8" name="confirm_password" placeholder="Re-taper le nouveau mot de passe" required type="password"/>
                                        </td>
                                    </tr>
                                    </table>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="col-span-1">
                    <div class="grid gap-5 lg:gap-7.5">
                        <!-- Basic Settings Card -->
                        <div class="kt-card min-w-full">
                            <div class="kt-card-header">
                                <h3 class="kt-card-title">Informations de l'Entreprise</h3>
                            </div>
                            <div class="kt-card-table pb-3" style="overflow: visible;">
                                <table class="kt-table align-middle text-sm text-muted-foreground">
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Nom du business *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-business-name-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="business_name"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" required type="text" value="{{ app.user ? app.user.businessName : '' }}" data-db-value="{{ app.user.businessName ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-business-name-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Numéro de téléphone du business *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-business-phone-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="business_phone"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" required type="text" value="{{ app.user ? app.user.businessPhone : '' }}" data-db-value="{{ app.user.businessPhone ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-business-phone-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Type de client *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-client-type-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="client_type"/>
                                                <select class="kt-select" name="value" required data-kt-select="true" data-kt-select-dropdown-parent="body" data-kt-select-enable-search="true" data-kt-select-placeholder="Choisir un type de client" data-kt-select-search-placeholder="Rechercher un type..." data-db-value="{{ app.user.clientType ?? '' }}">
                                                    <option value="" disabled {{ not (app.user and app.user.clientType) ? 'selected' : '' }}>Choisir un type</option>
                                                    <option value="E-commerce" {{ app.user and app.user.clientType == 'E-commerce' ? 'selected' : '' }}>E-commerce</option>
                                                    <option value="Auto Entrepreneur" {{ app.user and app.user.clientType == 'Auto Entrepreneur' ? 'selected' : '' }}>Auto Entrepreneur</option>
                                                    <option value="SARL" {{ app.user and app.user.clientType == 'SARL' ? 'selected' : '' }}>SARL</option>
                                                    <option value="SARLAU" {{ app.user and app.user.clientType == 'SARLAU' ? 'selected' : '' }}>SARLAU</option>
                                                    <option value="Autres" {{ app.user and app.user.clientType == 'Autres' ? 'selected' : '' }}>Autres</option>
                                                </select>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-client-type-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">I.C.E</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-ice-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="ice"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" placeholder="Non renseigné" type="text" value="{{ app.user and app.user.ice ? app.user.ice : '' }}" data-db-value="{{ app.user.ice ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-ice-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">R.C</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-rc-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="rc"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" placeholder="Non renseigné" type="text" value="{{ app.user and app.user.rc ? app.user.rc : '' }}" data-db-value="{{ app.user.rc ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-rc-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">Web site</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-website-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="website"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" placeholder="Non renseigné" type="text" value="{{ app.user and app.user.website ? app.user.website : '' }}" data-db-value="{{ app.user.website ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-website-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <div class="kt-card min-w-full">
                            <div class="kt-card-header">
                                <h3 class="kt-card-title">Informations bancaires</h3>
                            </div>
                            <div class="kt-card-table pb-3" style="overflow: visible;">
                                <table class="kt-table align-middle text-sm text-muted-foreground">
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Nom du banque *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-bank-name-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="bank_name"/>
                                                <select class="kt-select" name="value" required data-kt-select="true" data-kt-select-dropdown-parent="body" data-kt-select-enable-search="true" data-kt-select-placeholder="Choisir une banque" data-kt-select-search-placeholder="Rechercher une banque..." data-db-value="{{ app.user.bankName ?? '' }}">
                                                    <option value="" disabled {{ not (app.user and app.user.bankName) ? 'selected' : '' }}>Choisir une banque</option>
                                                    {% for bank in moroccanBanks %}
                                                        <option value="{{ bank }}" {{ app.user and app.user.bankName == bank ? 'selected' : '' }}>
                                                            {{ bank }}
                                                        </option>
                                                    {% endfor %}
                                                </select>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-bank-name-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-2 text-secondary-foreground font-normal">RIB (24 Numéro) *</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-bank-rib-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="bank_rib"/>
                                                <input class="kt-input h-8 text-sm bank-rib-input" inputmode="numeric" maxlength="32" minlength="24" name="value" pattern="\d{24}" required type="text" value="{{ app.user and app.user.bankRib ? app.user.bankRib : '' }}" data-db-value="{{ app.user.bankRib ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-bank-rib-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Return Address Card -->
                        <div class="kt-card min-w-full">
                            <div class="kt-card-header">
                                <h3 class="kt-card-title">Adresse de retour</h3>
                            </div>
                            <div class="kt-card-table pb-3" style="overflow: visible;">
                                <table class="kt-table align-middle text-sm text-muted-foreground">
                                    <tr>
                                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Réception colis retournés</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-return-reception-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="return_reception"/>
                                                <select class="kt-select" name="value" id="return-reception-select" required data-kt-select="true" data-kt-select-dropdown-parent="body" data-kt-select-minimum-results-for-search="Infinity" data-kt-select-placeholder="Choisir un mode de réception" data-db-value="{{ app.user.returnReception ?? 'En Agence' }}">
                                                    <option value="En ramassage" {{ app.user.returnReception is defined and app.user.returnReception == 'En ramassage' ? 'selected' : '' }}>En ramassage</option>
                                                    <option value="En Agence" {{ (app.user.returnReception is defined and app.user.returnReception == 'En Agence') or not (app.user.returnReception is defined and app.user.returnReception) ? 'selected' : '' }}>En Agence</option>
                                                </select>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-return-reception-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    
                                    <!-- Agency Dropdown (Visible only if En Agence) -->
                                    <tr id="agency-row" style="display: none;">
                                        <td class="py-2 text-secondary-foreground font-normal">Agence</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-return-agency-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="return_agency"/>
                                                <select class="kt-select" name="value" required data-kt-select="true" data-kt-select-dropdown-parent="body" data-kt-select-enable-search="true" data-kt-select-placeholder="Toutes nos agences" data-db-value="{{ app.user.returnAgency ?? '' }}">
                                                    <option value="" disabled {{ not (app.user.returnAgency is defined and app.user.returnAgency) ? 'selected' : '' }}>Toutes nos agences</option>
                                                    <option value="Agence Principale" {{ app.user.returnAgency is defined and app.user.returnAgency == 'Agence Principale' ? 'selected' : '' }}>Agence Principale</option>
                                                    <option value="Agence Secondaire" {{ app.user.returnAgency is defined and app.user.returnAgency == 'Agence Secondaire' ? 'selected' : '' }}>Agence Secondaire</option>
                                                </select>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-return-agency-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>

                                    <!-- Ramassage Fields (Visible only if En ramassage) -->
                                    <tr class="ramassage-row">
                                        <td class="py-2 text-secondary-foreground font-normal">Téléphone</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-return-phone-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="return_phone"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" placeholder="{{ app.user.businessPhone ?? 'Notre téléphone' }}" type="text" value="{{ app.user.returnPhone is defined and app.user.returnPhone ? app.user.returnPhone : (app.user.businessPhone ?? '') }}" data-db-value="{{ app.user.returnPhone ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-return-phone-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr class="ramassage-row">
                                        <td class="py-2 text-secondary-foreground font-normal">Ville</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-return-city-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="return_city"/>
                                                <select class="kt-select" name="value" required data-kt-select="true" data-kt-select-dropdown-parent="body" data-kt-select-enable-search="true" data-kt-select-placeholder="Choisir une ville" data-kt-select-search-placeholder="Rechercher une ville..." data-db-value="{{ app.user.returnCity ?? '' }}">
                                                    <option value="" disabled {{ not (app.user.returnCity is defined and app.user.returnCity) and not app.user.city ? 'selected' : '' }}>Choisir une ville</option>
                                                    {% for city in cities %}
                                                        <option value="{{ city.name }}" {{ (app.user.returnCity is defined and app.user.returnCity == city.name) or (not (app.user.returnCity is defined and app.user.returnCity) and app.user and app.user.city == city.name) ? 'selected' : '' }}>
                                                            {{ city.name }}
                                                        </option>
                                                    {% endfor %}
                                                </select>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-return-city-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr class="ramassage-row">
                                        <td class="py-2 text-secondary-foreground font-normal">Quartier</td>
                                        <td class="py-2 text-foreground font-normal text-sm">
                                            <form action="{{ path('app_profile_field_update') }}" id="profile-return-neighborhood-form" method="post">
                                                <input name="_token" type="hidden" value="{{ csrf_token('profile_field') }}"/>
                                                <input name="field" type="hidden" value="return_neighborhood"/>
                                                <input class="kt-input h-8 text-sm" maxlength="255" name="value" placeholder="Quartier" type="text" value="{{ app.user.returnNeighborhood is defined and app.user.returnNeighborhood ? app.user.returnNeighborhood : '' }}" data-db-value="{{ app.user.returnNeighborhood ?? '' }}"/>
                                            </form>
                                        </td>
                                        <td class="py-2 text-center">
                                            <button class="kt-btn kt-btn-icon kt-btn-sm kt-btn-ghost kt-btn-primary" form="profile-return-neighborhood-form" type="submit">
                                                <i class="ki-filled ki-check"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- end: grid -->
        </div>
        <!-- End of Container -->
    </main>
    <!-- End of Content -->
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/profile.js') }}"></script>
{% endblock %}
