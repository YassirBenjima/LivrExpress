{% extends 'base_dashboard.html.twig' %}

{% set is_edit_mode = is_edit_mode|default(false) %}

{% block title %}Suivi par Whatsapp - LivrExpress{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link href="{{ asset('assets/css/tracking-whatsapp-template.css') }}" rel="stylesheet" type="text/css" />
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="{{ asset('assets/js/tracking-whatsapp-template.js') }}"></script>
{% endblock %}

{% block body %}
<main class="grow pt-5 dashboard-content-shift" id="content" role="content">
  <div class="kt-container-fixed">
    <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
      <div class="flex flex-col justify-center gap-2">
        <h1 class="text-xl font-medium leading-none text-mono">Suivi par Whatsapp</h1>
        <div class="text-sm font-normal text-secondary-foreground">
          Utilisez les placeholders dans votre message: {{ allowed_placeholders|join(', ') }}.
        </div>
        <div class="text-2sm text-secondary-foreground">
          <span class="font-medium text-foreground">Exemple:</span> {{ message_preview }}
        </div>
      </div>
    </div>
  </div>

  <div class="kt-container-fixed">
    <div class="kt-card border border-border/60 mb-5">
      <div class="kt-card-content p-4 lg:p-5">
        <div class="flex items-center justify-between flex-wrap gap-3 mb-4">
          <h3 class="text-sm font-semibold text-foreground">
            {{ is_edit_mode ? 'Modifier le modèle WhatsApp' : 'Créer un modèle WhatsApp' }}
          </h3>
          {% if is_edit_mode %}
            <a class="kt-btn kt-btn-outline" href="{{ path('app_suivi_modele_whatsapp') }}">
              Annuler la modification
            </a>
          {% endif %}
        </div>

        {{ form_start(form, { attr: { class: 'grid grid-cols-1 gap-4', novalidate: 'novalidate' } }) }}
          {{ form_errors(form) }}
          <div class="grid gap-1.5">
            <label class="text-sm font-medium text-mono">{{ form_label(form.title) }}</label>
            {{ form_widget(form.title) }}
            <div class="text-2sm text-destructive">{{ form_errors(form.title) }}</div>
          </div>

          <div class="grid gap-1.5">
            <label class="text-sm font-medium text-mono">{{ form_label(form.message) }}</label>
            {{ form_widget(form.message) }}
            <div class="text-2sm text-destructive">{{ form_errors(form.message) }}</div>
            <div class="flex items-center justify-between flex-wrap gap-2 text-2sm text-secondary-foreground">
              <span>Placeholders autorisés: {{ allowed_placeholders|join(', ') }}</span>
              <span data-whatsapp-message-counter="true" data-soft-limit="{{ message_soft_limit }}" data-hard-limit="{{ message_hard_limit }}">
                0/{{ message_hard_limit }}
              </span>
            </div>
            <div class="text-2sm text-warning hidden" data-whatsapp-message-warning="true">
              Message long: vérifiez que WhatsApp affiche correctement tout le texte.
            </div>
          </div>

          <div class="flex justify-end">
            <button class="kt-btn kt-btn-primary w-full lg:w-auto" type="submit">
              {{ is_edit_mode ? 'Enregistrer' : 'Nouveau' }}
            </button>
          </div>
        {{ form_end(form) }}
      </div>
    </div>
  </div>

  <div class="kt-container-fixed">
    <div class="kt-card kt-card-grid min-w-full">
      <div class="kt-card-header flex-wrap gap-2">
        <h3 class="kt-card-title text-sm" data-whatsapp-count-label="true">Affichage de {{ templates|length }} modèle(s)</h3>
        <form class="flex flex-wrap gap-2 lg:gap-5" method="get" action="{{ path('app_suivi_modele_whatsapp') }}">
          <div class="flex">
            <label class="kt-input">
              <i class="ki-filled ki-magnifier"></i>
              <input
                data-kt-datatable-search="#whatsapp_templates_table"
                data-whatsapp-live-search="true"
                name="q"
                placeholder="Rechercher un modèle..."
                type="text"
                value="{{ search_query|default('') }}"
              />
            </label>
          </div>
          <div class="flex flex-wrap gap-2.5">
            <select
              class="kt-select w-36"
              data-kt-select="true"
              data-kt-select-placeholder="Statut"
              data-whatsapp-status-filter="true"
              name="status"
            >
              <option value="">Tous les statuts</option>
              {% for statusValue, statusLabel in status_options %}
                <option value="{{ statusValue }}" {{ selected_status|default('') == statusValue ? 'selected' : '' }}>
                  {{ statusLabel }}
                </option>
              {% endfor %}
            </select>
            <button class="kt-btn kt-btn-outline kt-btn-primary" type="submit">
              <i class="ki-filled ki-setting-4"></i>
              Filtrer
            </button>
            <a class="kt-btn kt-btn-outline" href="{{ path('app_suivi_modele_whatsapp') }}">
              Réinitialiser
            </a>
          </div>
        </form>
      </div>

      <div class="kt-card-content">
        <div data-kt-datatable="true" data-kt-datatable-state-save="false" id="whatsapp_templates_table">
          <div class="kt-scrollable-x-auto">
            <table class="kt-table table-auto kt-table-border" data-kt-datatable-table="true">
              <thead>
                <tr>
                  <th class="min-w-[180px]">
                    <span class="kt-table-col">
                      <span class="kt-table-col-label">Titre</span>
                      <span class="kt-table-col-sort"></span>
                    </span>
                  </th>
                  <th class="min-w-[220px]">
                    <span class="kt-table-col">
                      <span class="kt-table-col-label">Message</span>
                      <span class="kt-table-col-sort"></span>
                    </span>
                  </th>
                  <th class="min-w-[170px]">
                    <span class="kt-table-col">
                      <span class="kt-table-col-label">Date de création</span>
                      <span class="kt-table-col-sort"></span>
                    </span>
                  </th>
                  <th class="min-w-[130px]">
                    <span class="kt-table-col">
                      <span class="kt-table-col-label">Statut</span>
                      <span class="kt-table-col-sort"></span>
                    </span>
                  </th>
                  <th class="w-[90px] text-center">
                    <span class="kt-table-col">
                      <span class="kt-table-col-label">Actions</span>
                    </span>
                  </th>
                </tr>
              </thead>
              <tbody>
                {% for template in templates %}
                  {% set isDefaultModel = template.isDefault %}
                  {% set isActiveModel = template.status == 'active' %}
                  {% set statusClass = isActiveModel ? 'kt-badge-success' : 'kt-badge-destructive' %}
                  {% set statusLabel = isActiveModel ? 'Activé' : 'Désactivé' %}
                  <tr data-whatsapp-template-row="true" data-whatsapp-template-status="{{ template.status }}">
                    <td class="text-foreground font-medium">{{ template.title }}</td>
                    <td class="text-foreground font-normal">
                      <span class="truncate-text inline-block max-w-[220px] align-bottom" title="{{ template.message }}">
                        {{ template.message }}
                      </span>
                    </td>
                    <td class="text-foreground font-normal">{{ template.createdAt ? template.createdAt|date('d/m/Y H:i') : '-' }}</td>
                    <td>
                      <div class="flex items-center gap-1.5">
                        {% if isDefaultModel %}
                          <span class="kt-badge kt-badge-info kt-badge-outline rounded-[30px]">
                            <span class="kt-badge-dot size-1.5"></span>
                            Default
                          </span>
                        {% endif %}
                        <span class="kt-badge {{ statusClass }} kt-badge-outline rounded-[30px]">
                          <span class="kt-badge-dot size-1.5"></span>
                          {{ statusLabel }}
                        </span>
                      </div>
                    </td>
                    <td class="text-center">
                      <div class="kt-menu flex-inline" data-kt-menu="true">
                        <div class="kt-menu-item" data-kt-menu-item-offset="0, 10px" data-kt-menu-item-placement="bottom-end" data-kt-menu-item-placement-rtl="bottom-start" data-kt-menu-item-toggle="dropdown" data-kt-menu-item-trigger="click">
                          <button class="kt-menu-toggle kt-btn kt-btn-sm kt-btn-icon kt-btn-ghost" type="button">
                            <i class="ki-filled ki-dots-vertical text-lg"></i>
                          </button>
                          <div class="kt-menu-dropdown kt-menu-default w-full max-w-[220px]" data-kt-menu-dismiss="true">
                            <div class="kt-menu-item">
                              {% if isDefaultModel %}
                                <button class="kt-menu-link w-full text-start opacity-60 cursor-not-allowed" type="button" disabled aria-disabled="true">
                                  <span class="kt-menu-icon"><i class="ki-filled ki-lock-2"></i></span>
                                  <span class="kt-menu-title">Modification verrouillée</span>
                                </button>
                              {% else %}
                                <a class="kt-menu-link" href="{{ path('app_suivi_modele_whatsapp', { edit: template.id }) }}">
                                  <span class="kt-menu-icon"><i class="ki-filled ki-pencil"></i></span>
                                  <span class="kt-menu-title">Modifier</span>
                                </a>
                              {% endif %}
                            </div>
                            <div class="kt-menu-item">
                              {% if isDefaultModel %}
                                <button class="kt-menu-link w-full text-start opacity-60 cursor-not-allowed" type="button" disabled aria-disabled="true">
                                  <span class="kt-menu-icon"><i class="ki-filled ki-lock-2"></i></span>
                                  <span class="kt-menu-title">Statut verrouillé (Default)</span>
                                </button>
                              {% else %}
                                <form method="post" action="{{ path('app_suivi_modele_whatsapp_toggle_status', { id: template.id }) }}">
                                  <input type="hidden" name="_token" value="{{ csrf_token('toggle_whatsapp_template_' ~ template.id) }}">
                                  <button class="kt-menu-link w-full text-start" type="submit">
                                    <span class="kt-menu-icon"><i class="ki-filled ki-arrows-circle"></i></span>
                                    <span class="kt-menu-title">{{ template.status == 'active' ? 'Désactiver' : 'Activer' }}</span>
                                  </button>
                                </form>
                              {% endif %}
                            </div>
                            <div class="kt-menu-item">
                              {% if isDefaultModel %}
                                <button class="kt-menu-link w-full text-start opacity-60 cursor-not-allowed" type="button" disabled aria-disabled="true">
                                  <span class="kt-menu-icon"><i class="ki-filled ki-lock-2"></i></span>
                                  <span class="kt-menu-title">Suppression verrouillée</span>
                                </button>
                              {% else %}
                                <button
                                  class="kt-menu-link w-full text-start text-destructive"
                                  type="button"
                                  data-kt-modal-toggle="#whatsapp_template_delete_modal"
                                  data-whatsapp-delete-open="true"
                                  data-template-id="{{ template.id }}"
                                  data-template-title="{{ template.title }}"
                                  data-template-token="{{ csrf_token('delete_whatsapp_template_' ~ template.id) }}"
                                >
                                  <span class="kt-menu-icon"><i class="ki-filled ki-trash"></i></span>
                                  <span class="kt-menu-title">Supprimer</span>
                                </button>
                              {% endif %}
                            </div>
                          </div>
                        </div>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr>
                    <td colspan="5" class="text-secondary-foreground text-center py-8">
                      Aucun modèle WhatsApp trouvé.
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <div class="kt-card-footer justify-center md:justify-between flex-col md:flex-row gap-5 text-secondary-foreground text-sm font-medium">
            <div class="flex items-center gap-2 order-2 md:order-1">
              Afficher
              <select class="kt-select w-16" data-kt-datatable-size="true" data-kt-select="" name="perpage"></select>
              par page
            </div>
            <div class="flex items-center gap-4 order-1 md:order-2">
              <span data-kt-datatable-info="true"></span>
              <div class="kt-datatable-pagination" data-kt-datatable-pagination="true"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<div class="kt-modal" data-kt-modal="true" id="whatsapp_template_delete_modal">
  <div class="kt-modal-content top-5 lg:top-[20%] w-full max-w-[460px]">
    <div class="kt-modal-header">
      <h3 class="kt-modal-title">Supprimer le modèle</h3>
      <button class="kt-btn kt-btn-sm kt-btn-icon kt-btn-ghost shrink-0" data-kt-modal-dismiss="true" type="button">
        <i class="ki-filled ki-cross"></i>
      </button>
    </div>
    <div class="kt-modal-body px-5 py-5">
      <p class="text-sm text-secondary-foreground mb-4">
        Vous êtes sur le point de supprimer le modèle <span class="font-medium text-foreground" data-whatsapp-delete-title="true"></span>.
      </p>
      <form id="whatsapp-template-delete-form" method="post" action="">
        <input type="hidden" name="_token" value="" data-whatsapp-delete-token="true">
        <div class="flex items-center justify-end gap-2">
          <button class="kt-btn kt-btn-outline" data-kt-modal-dismiss="true" type="button">Annuler</button>
          <button class="kt-btn kt-btn-destructive" type="submit">Supprimer</button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
