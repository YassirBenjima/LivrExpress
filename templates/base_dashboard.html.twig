<!DOCTYPE html>
<html class="h-full" data-kt-theme="true" data-kt-theme-mode="light" dir="ltr" lang="fr">
<head>
    <title>{% block title %}LivrExpress - Dashboard{% endblock %}</title>
    {% include 'partials/_dashboard_head.html.twig' %}
    <link href="{{ asset('assets/css/dashboard-custom.css?v=1') }}" rel="stylesheet"/>
    {% block stylesheets %}{% endblock %}
</head>
<body class="antialiased flex h-full text-base text-foreground bg-background demo1 kt-sidebar-fixed kt-header-fixed">
    <!-- Theme Mode -->
    <script>
        const defaultThemeMode = 'light'; // light|dark|system
        let themeMode;

        if (document.documentElement) {
            if (localStorage.getItem('kt-theme')) {
                themeMode = localStorage.getItem('kt-theme');
            } else if (
                document.documentElement.hasAttribute('data-kt-theme-mode')
            ) {
                themeMode =
                    document.documentElement.getAttribute('data-kt-theme-mode');
            } else {
                themeMode = defaultThemeMode;
            }

            if (themeMode === 'system') {
                themeMode = window.matchMedia('(prefers-color-scheme: dark)').matches
                    ? 'dark'
                    : 'light';
            }

            document.documentElement.classList.add(themeMode);
        }
    </script>
    <!-- End of Theme Mode -->

    {% include 'partials/_flash_messages.html.twig' %}

    <!-- Main -->
    <div class="gap-2" id="page">
        {% include 'partials/_dashboard_sidebar.html.twig' %}
        
        <!-- Wrapper -->
        <div class="kt-wrapper flex grow flex-col ms-2" id="wrapper">
            {% include 'partials/_dashboard_header.html.twig' %}
            
            <!-- Content -->
            {% block body %}{% endblock %}
            <!-- End of Content -->
            
            {% include 'partials/_dashboard_footer.html.twig' %}
        </div>  
        <!-- End of Wrapper -->
    </div>
    <!-- End of Main -->

    <!-- Extras (Drawers & Modals) -->
    {% include 'partials/_dashboard_extras.html.twig' %}

    <!-- Scripts -->
    <script src="{{ asset('assets/js/core.bundle.js') }}"></script>
    <script src="{{ asset('assets/vendors/ktui/ktui.min.js') }}"></script>
    <script src="{{ asset('assets/vendors/apexcharts/apexcharts.min.js') }}"></script>
    <script src="{{ asset('assets/js/widgets/general.js') }}"></script>
    <script src="{{ asset('assets/js/layouts/demo1.js') }}"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
