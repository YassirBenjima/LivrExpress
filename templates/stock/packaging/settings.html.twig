{% extends 'base_dashboard.html.twig' %}

{% block title %}Gestion d'emballage - LivrExpress{% endblock %}

{% block body %}
<main class="grow pt-5 dashboard-content-shift" id="content" role="content" data-user-settings-root="true" data-user-settings-page="packaging">
    <div class="kt-container-fixed">
        <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
            <div class="flex flex-col justify-center gap-2">
                <h1 class="text-xl font-medium leading-none text-mono">
                    Gestion d'emballage
                </h1>
                <div class="flex items-center gap-2 text-sm font-normal text-secondary-foreground">
                    Veuillez choisir votre configuration d'emballage
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-5 lg:gap-7.5">
            <div class="col-span-1">
                <div class="kt-card">
                    <div class="kt-card-header">
                        <h3 class="kt-card-title">Cartons</h3>
                    </div>
                    <div class="kt-card-content pb-7.5 px-4 sm:px-6">
                        <div class="text-sm font-normal text-secondary-foreground mb-3">
                            Définissez votre configuration pour les colis cartons
                        </div>
                        <div class="grid gap-2.5">
                            <div class="flex items-start sm:items-center justify-between group border border-border rounded-xl gap-3 px-3.5 py-2.5">
                                <div class="flex items-center gap-2.5 min-w-0 flex-1">
                                    <div class="size-[50px] shrink-0 rounded-xl bg-muted/60 flex items-center justify-center">
                                        <i class="ki-filled ki-shield-cross text-2xl text-muted-foreground"></i>
                                    </div>
                                    <div class="flex flex-col min-w-0">
                                        <span class="text-mono text-sm font-medium">Aucune</span>
                                        <span class="text-xs text-secondary-foreground">Je n'ai pas besoin de cartons</span>
                                    </div>
                                </div>
                                <button class="kt-btn kt-btn-sm kt-btn-icon kt-btn-primary kt-btn-outline rounded-full shrink-0 self-start sm:self-center" type="button" data-badge-check="true" data-packaging-category="cartons" data-packaging-choice="none" aria-pressed="false">
                                    <i class="ki-filled ki-check"></i>
                                </button>
                            </div>
                            <div class="flex items-start sm:items-center justify-between group border border-border rounded-xl gap-3 px-3.5 py-2.5">
                                <div class="flex items-center gap-2.5 min-w-0 flex-1">
                                    <div class="size-[50px] shrink-0 rounded-xl bg-muted/60 flex items-center justify-center">
                                        <i class="ki-filled ki-cube-2 text-2xl text-muted-foreground"></i>
                                    </div>
                                    <div class="flex flex-col min-w-0">
                                        <span class="text-mono text-sm font-medium">Petit carton (S)</span>
                                        <span class="text-xs text-secondary-foreground">Avec frais: 1.5 DH</span>
                                        <span class="text-xs text-secondary-foreground">Carton box de petite taille.</span>
                                    </div>
                                </div>
                                <button class="kt-btn kt-btn-sm kt-btn-icon kt-btn-primary kt-btn-outline rounded-full shrink-0 self-start sm:self-center" type="button" data-badge-check="true" data-packaging-category="cartons" data-packaging-choice="S" aria-pressed="false">
                                    <i class="ki-filled ki-check"></i>
                                </button>
                            </div>
