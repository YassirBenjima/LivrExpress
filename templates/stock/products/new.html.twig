{% extends 'base_dashboard.html.twig' %}

{% block title %}Ajouter un produit - LivrExpress{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link href="{{ asset('assets/css/stock-products-new.css?v=1') }}" rel="stylesheet"/>
{% endblock %}



{% block body %}
<main class="grow pt-5 profile-content-shift" id="content" role="content">
  <div class="kt-container-fixed">
    {% include 'partials/_flash_messages.html.twig' with { flash_inline: true } %}
    <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
      <div class="flex flex-col justify-center gap-2">
        <h1 class="text-xl font-medium leading-none text-mono">
          Ajouter un produit
        </h1>
        <div class="flex items-center gap-2 text-sm font-normal text-secondary-foreground">
          Créez un produit
        </div>
      </div>
      <div class="flex flex-col items-end gap-2.5">
        <div class="flex items-center gap-2.5">
          <a class="kt-btn kt-btn-outline" href="{{ path('app_stock_products_index') }}">
            Retour a la liste
          </a>
          <button class="kt-btn kt-btn-primary" form="product-new-form" id="product-save-btn" type="submit">
            Enregistrer
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="kt-container-fixed">
    <div class="grid grid-cols-1 gap-5 lg:gap-7.5">

      <div class="col-span-1">
        <form id="product-new-form" method="post" action="{{ path('app_stock_products_create') }}" enctype="multipart/form-data">
          <input type="hidden" name="_token" value="{{ csrf_token('stock_product_new') }}"/>
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-5 lg:gap-7.5">
          <div class="col-span-1">
            <div class="kt-card min-w-full">
              <div class="kt-card-header">
                <h3 class="kt-card-title">Informations du produit</h3>
              </div>
              <div class="kt-card-table pb-3" style="overflow: visible;">
                <table class="kt-table align-middle text-sm text-muted-foreground">
                      <tr>
                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Photo</td>
                        <td class="py-2 text-secondary-foreground font-normal text-sm">Image du produit (JPG/PNG)</td>
                        <td class="py-2 text-center">
                          <div class="flex justify-center items-center">
                            <div class="kt-image-input size-16" data-kt-image-input="true">
                              <input accept=".png, .jpg, .jpeg" name="photo" type="file"/>
                              <input name="photo_remove" type="hidden"/>
                              <button class="kt-image-input-remove" data-kt-image-input-remove="true" data-kt-tooltip="true" data-kt-tooltip-placement="right" data-kt-tooltip-trigger="hover" type="button">
                                <i class="ki-filled ki-cross"></i>
                                <span class="kt-tooltip" data-kt-tooltip-content="true">Cliquer pour supprimer ou annuler</span>
                              </button>
                              <div class="kt-image-input-placeholder border-2 border-input kt-image-input-empty:border-input" data-kt-image-input-placeholder="true">
                                <div class="kt-image-input-preview" data-kt-image-input-preview="true" style="background-image:url('{{ asset('assets/media/avatars/blank1.png') }}');"></div>
                                <div class="flex items-center justify-center cursor-pointer h-5 left-0 right-0 bottom-0 bg-black/25 absolute">
                                  <svg class="fill-border opacity-80" height="12" viewbox="0 0 14 12" width="14" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M11.6665 2.64585H11.2232C11.0873 2.64749 10.9538 2.61053 10.8382 2.53928C10.7225 2.46803 10.6295 2.36541 10.5698 2.24335L10.0448 1.19918C9.91266 0.931853 9.70808 0.707007 9.45438 0.550249C9.20068 0.393491 8.90806 0.311121 8.60984 0.312517H5.38984C5.09162 0.311121 4.799 0.393491 4.5453 0.550249C4.2916 0.707007 4.08701 0.931853 3.95484 1.19918L3.42984 2.24335C3.37021 2.36541 3.27716 2.46803 3.1615 2.53928C3.04584 2.61053 2.91234 2.64749 2.7765 2.64585H2.33317C1.90772 2.64585 1.49969 2.81486 1.19885 3.1157C0.898014 3.41654 0.729004 3.82457 0.729004 4.25002V10.0834C0.729004 10.5088 0.898014 10.9168 1.19885 11.2177C1.49969 11.5185 1.90772 11.6875 2.33317 11.6875H11.6665C12.092 11.6875 12.5 11.5185 12.8008 11.2177C13.1017 10.9168 13.2707 10.5088 13.2707 10.0834V4.25002C13.2707 3.82457 13.1017 3.41654 12.8008 3.1157C12.5 2.81486 12.092 2.64585 11.6665 2.64585ZM6.99984 9.64585C6.39413 9.64585 5.80203 9.46624 5.2984 9.12973C4.79478 8.79321 4.40225 8.31492 4.17046 7.75532C3.93866 7.19572 3.87802 6.57995 3.99618 5.98589C4.11435 5.39182 4.40602 4.84613 4.83432 4.41784C5.26262 3.98954 5.80831 3.69786 6.40237 3.5797C6.99644 3.46153 7.61221 3.52218 8.1718 3.75397C8.7314 3.98576 9.2097 4.37829 9.54621 4.88192C9.88272 5.38554 10.0623 5.97765 10.0623 6.58335C10.0608 7.3951 9.73765 8.17317 9.16365 8.74716C8.58965 9.32116 7.81159 9.64431 7 9.64585Z"></path>
                                    <path d="M7 8.77087C8.20812 8.77087 9.1875 7.7915 9.1875 6.58337C9.1875 5.37525 8.20812 4.39587 7 4.39587C5.79188 4.39587 4.8125 5.37525 4.8125 6.58337C4.8125 7.7915 5.79188 8.77087 7 8.77087Z"></path>
                                  </svg>
                                </div>
                              </div>
                            </div>
                          </div>
                        </td>
                      </tr>
                      <tr>
                        <td class="py-2 min-w-36 text-secondary-foreground font-normal">Nom du produit</td>
                        <td class="py-2 text-foreground font-normal text-sm">
                          <input class="kt-input h-8 text-sm" name="name" placeholder="Nom du produit" type="text" required/>
                        </td>
                        <td class="py-2 text-center">
                        </td>
                      </tr>
  
                    <tr>
                      <td class="py-2 text-secondary-foreground font-normal">Catégorie</td>
                      <td class="py-2 text-foreground font-normal text-sm">
                        <select
                          class="kt-select"
                          name="category"
                          required
                          data-kt-select="true"
                          data-kt-select-dropdown-parent="body"
                          data-kt-select-enable-search="true"
                          data-kt-select-placeholder="Choisir une catégorie"
                          data-kt-select-search-placeholder="Rechercher une catégorie..."
                        >
                          <option value="" disabled selected>Choisir une catégorie</option>
                          <option value="1">Vêtements &amp; Accessoires</option>
                          <option value="2">Caméras et optiques</option>
                          <option value="3">Électronique</option>
                          <option value="4">Santé &amp; Beauté</option>
                          <option value="5">Maison &amp; Jardin</option>
                          <option value="6">Fournitures de bureau</option>
                          <option value="7">Articles de sport</option>
                          <option value="8">Jouets</option>
                          <option value="9">Pièces</option>
                          <option value="10">Animaux et fournitures pour animaux</option>
                          <option value="11">Autres</option>
                        </select>
                      </td>
                      <td class="py-2 text-center">
                      </td>
                    </tr>
                    <tr id="barcode-row">
                      <td class="py-2 text-secondary-foreground font-normal">Votre Code Barre</td>
                      <td class="py-2 text-foreground font-normal text-sm">
                        <input class="kt-input h-8 text-sm" name="barcode" placeholder="Code barre" type="text"/>
                      </td>
                      <td class="py-2 text-center">
                      </td>
                    </tr>
                    <tr id="quantity-row">
                      <td class="py-2 min-w-36 text-secondary-foreground font-normal">Quantité</td>
                      <td class="py-2 text-foreground font-normal text-sm">
                        <input class="kt-input h-8 text-sm" inputmode="numeric" name="quantity" pattern="[0-9]*" placeholder="Quantité" type="text" required oninput="this.value=this.value.replace(/[^0-9]/g,'')"/>
                      </td>
                      <td class="py-2 text-center">
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 text-secondary-foreground font-normal">Note du produit</td>
                      <td class="py-2 text-foreground font-normal text-sm">
                        <input class="kt-input h-8 text-sm" name="note" placeholder="Note" type="text"/>
                      </td>
                      <td class="py-2 text-center">
                      </td>
                    </tr>
                    </table>
              </div>
            </div>
          </div>

          <div class="col-span-1">
            <div class="kt-card min-w-full">
              <div class="kt-card-header">
                <h3 class="kt-card-title">Détails</h3>
                <div class="flex items-center gap-2">
                  <label class="kt-label">
                    Variantes
                    <input class="kt-switch kt-switch-sm" id="variants-toggle" name="variants_enabled" type="checkbox"/>
                  </label>
                </div>
              </div>
              <div class="kt-card-table pb-3" style="overflow: visible;">
                <div class="px-6 py-5" id="variants-section" style="display:none;">
                  <table class="kt-table align-middle text-sm text-muted-foreground">
                      <thead>
                        <tr class="text-secondary-foreground">
                          <th class="py-2 min-w-40 font-normal">Votre Code Barre</th>
                          <th class="py-2 min-w-44 font-normal">Nom de la variante</th>
                          <th class="py-2 min-w-28 font-normal">Quantité</th>
                          <th class="py-2 w-[60px]"></th>
                        </tr>
                      </thead>
                      <tbody id="variants-tbody">
                        <tr class="variant-row">
                          <td class="py-2">
                            <input class="kt-input h-8 text-sm w-full" name="variants[0][barcode]" placeholder="Code barre" type="text"/>
                          </td>
                          <td class="py-2">
                            <input class="kt-input h-8 text-sm w-full" name="variants[0][name]" placeholder="Nom de la variante" type="text"/>
                          </td>
                          <td class="py-2">
                            <input class="kt-input h-8 text-sm w-full" inputmode="numeric" name="variants[0][quantity]" pattern="[0-9]*" placeholder="0" type="text" oninput="this.value=this.value.replace(/[^0-9]/g,'')"/>
                          </td>
                          <td class="py-2 text-end">
                            <span class="text-xs text-secondary-foreground select-none">
                              &nbsp;
                            </span>
                          </td>
                        </tr>
                      </tbody>
                    </table>

                  <div class="pt-4 flex justify-end pr-2">
                    <button class="kt-btn kt-btn-outline kt-btn-primary" id="add-variant-btn" type="button">
                      <i class="ki-filled ki-plus"></i>
                      Ajouter une variante
                    </button>
                  </div>
                </div>

                <div class="px-6 py-5 text-sm text-secondary-foreground" id="variants-empty">
                  &nbsp;
                </div>
              </div>
            </div>
          </div>
        </div>
        </form>
      </div>
    </div>
  </div>
</main>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="{{ asset('assets/js/stock-products-new.js') }}"></script>
{% endblock %}

