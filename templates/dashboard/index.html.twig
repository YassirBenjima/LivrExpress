{% extends 'base_dashboard.html.twig' %}

{% block title %}Tableau de Bord - LivrExpress{% endblock %}

{% block body %}
<main class="grow pt-5 dashboard-content-shift" id="content" role="content">
  <!-- Header Container -->
  <div class="kt-container-fixed">
    <div class="flex flex-wrap items-center justify-between gap-5 pb-7.5">
      <div class="flex flex-col justify-center gap-2">
        <h1 class="text-xl font-medium leading-none text-mono">
          Tableau de Bord
        </h1>
        <div class="flex items-center gap-2 text-sm font-normal text-secondary-foreground">
          Aperçu global de l'activité logistique et financière de LivrExpress
        </div>
      </div>
      <div class="flex items-center gap-2.5">
        <a class="kt-btn kt-btn-outline" href="{{ path('app_colis_new') }}">
          <i class="ki-filled ki-plus text-base"></i>
          Nouveau Colis
        </a>
        <a class="kt-btn kt-btn-primary" href="{{ path('app_bon_livraison_new') }}">
          <i class="ki-filled ki-plus text-base"></i>
          Nouveau Bon
        </a>
      </div>
    </div>
  </div>

  <!-- Key Statistics Grid -->
  <div class="kt-container-fixed mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-5 lg:gap-7.5">
      <!-- Card 1: Total Colis -->
      <div class="kt-card p-5 flex flex-col justify-between border border-border/60 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-medium text-secondary-foreground">Total Colis</span>
          <div class="bg-primary/10 text-primary rounded-lg p-2">
            <i class="ki-filled ki-package text-xl"></i>
          </div>
        </div>
        <div>
          <span class="text-3xl font-semibold text-mono block mb-1">{{ totalColis }}</span>
          <span class="text-xs text-secondary-foreground">Enregistrés au total</span>
        </div>
      </div>

      <!-- Card 2: Colis Livrés -->
      <div class="kt-card p-5 flex flex-col justify-between border border-border/60 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-medium text-secondary-foreground">Colis Livrés</span>
          <div class="bg-success/10 text-success rounded-lg p-2">
            <i class="ki-filled ki-verify text-xl"></i>
          </div>
        </div>
        <div>
          <span class="text-3xl font-semibold text-mono block mb-1 text-success">{{ colisLivres }}</span>
          <span class="text-xs text-secondary-foreground">
            {% if totalColis > 0 %}
              {{ ((colisLivres / totalColis) * 100)|number_format(1) }}% de taux de livraison
            {% else %}
              0% de taux de livraison
            {% endif %}
          </span>
        </div>
      </div>

      <!-- Card 3: En Cours -->
      <div class="kt-card p-5 flex flex-col justify-between border border-border/60 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-medium text-secondary-foreground">En Transit</span>
          <div class="bg-info/10 text-info rounded-lg p-2">
            <i class="ki-filled ki-delivery-3 text-xl"></i>
          </div>
        </div>
        <div>
          <span class="text-3xl font-semibold text-mono block mb-1 text-info">{{ colisExpedies + colisEnPreparation }}</span>
          <span class="text-xs text-secondary-foreground">{{ colisExpedies }} expédié(s) | {{ colisEnPreparation }} en préparation</span>
        </div>
      </div>

      <!-- Card 4: Retournés -->
      <div class="kt-card p-5 flex flex-col justify-between border border-border/60 hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-medium text-secondary-foreground font-mono">Retournés / Échecs</span>
          <div class="bg-destructive/10 text-destructive rounded-lg p-2">
            <i class="ki-filled ki-cross text-xl"></i>
          </div>
        </div>
        <div>
          <span class="text-3xl font-semibold text-mono block mb-1 text-destructive">{{ colisRetournes }}</span>
          <span class="text-xs text-secondary-foreground">Retour à l'expéditeur</span>
        </div>
      </div>

      <!-- Card 5: Finance Details -->
      <div class="kt-card p-5 flex flex-col justify-between border border-border/60 bg-gradient-to-br from-indigo-900/10 to-transparent hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-medium text-secondary-foreground">Recettes CRBT</span>
          <div class="bg-primary/20 text-primary rounded-lg p-2">
            <i class="ki-filled ki-wallet text-xl"></i>
          </div>
        </div>
        <div>
          <span class="text-2xl font-bold text-mono block mb-1 text-primary">{{ crbtLivres|number_format(2, ',', ' ') }} MAD</span>
          <div class="text-2xs text-secondary-foreground">
            <span class="font-medium text-foreground">En attente :</span> {{ crbtEnCours|number_format(0, ',', ' ') }} MAD
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Layout -->
  <div class="kt-container-fixed mb-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-7.5">
      <!-- Chart 1: Volume trends -->
      <div class="kt-card lg:col-span-2 border border-border/60">
        <div class="kt-card-header">
          <h3 class="kt-card-title text-base font-semibold">Volume des Colis Enregistrés (7 derniers jours)</h3>
        </div>
        <div class="kt-card-content p-5">
          <div id="volume_chart"></div>
        </div>
      </div>

      <!-- Chart 2: State Distribution -->
      <div class="kt-card border border-border/60">
        <div class="kt-card-header">
          <h3 class="kt-card-title text-base font-semibold">Statistiques par État</h3>
        </div>
        <div class="kt-card-content p-5">
          <div id="state_chart"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Tables Container -->
  <div class="kt-container-fixed">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 lg:gap-7.5">
      
      <!-- Recent Parcels -->
      <div class="kt-card border border-border/60">
        <div class="kt-card-header flex items-center justify-between">
          <h3 class="kt-card-title text-base font-semibold">Derniers Colis Enregistrés</h3>
          <a class="text-xs text-primary font-medium hover:underline" href="{{ path('app_colis_index') }}">Voir tout</a>
        </div>
        <div class="kt-card-content p-0">
          <div class="kt-scrollable-x-auto">
            <table class="kt-table table-auto w-full text-sm">
              <thead>
                <tr class="border-b border-border/40">
                  <th class="py-3 px-4 text-left font-semibold text-secondary-foreground">Code</th>
                  <th class="py-3 px-4 text-left font-semibold text-secondary-foreground">Destinataire</th>
                  <th class="py-3 px-4 text-left font-semibold text-secondary-foreground">Ville</th>
                  <th class="py-3 px-4 text-left font-semibold text-secondary-foreground">Prix</th>
                  <th class="py-3 px-4 text-center font-semibold text-secondary-foreground">État</th>
                </tr>
              </thead>
              <tbody>
                {% for colis in recentColis %}
                  <tr class="border-b border-border/20 hover:bg-muted/30">
                    <td class="py-3 px-4 font-medium text-foreground">
                      <a href="{{ path('app_colis_edit', {id: colis.id}) }}" class="hover:text-primary transition-colors">
                        {{ colis.trackingCode }}
                      </a>
                    </td>
                    <td class="py-3 px-4 text-foreground font-normal">{{ colis.recipient ?: '-' }}</td>
                    <td class="py-3 px-4 text-foreground font-normal">{{ colis.city }}</td>
                    <td class="py-3 px-4 text-foreground font-medium">{{ colis.price|number_format(2, ',', ' ') }} MAD</td>
                    <td class="py-3 px-4 text-center">
                      <span class="kt-badge {{ colis.etatBadgeClass }} kt-badge-outline rounded-[30px] px-2 py-0.5">
                        {{ colis.etatLabel }}
                      </span>
                    </td>
                  </tr>
                {% else %}
                  <tr>
                    <td colspan="5" class="py-8 text-center text-secondary-foreground">Aucun colis disponible</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Recent Delivery Notes -->
      <div class="kt-card border border-border/60">
        <div class="kt-card-header flex items-center justify-between">
          <h3 class="kt-card-title text-base font-semibold">Derniers Bons de Livraison</h3>
          <a class="text-xs text-primary font-medium hover:underline" href="{{ path('app_bon_livraison_index') }}">Voir tout</a>
        </div>
        <div class="kt-card-content p-0">
          <div class="kt-scrollable-x-auto">
            <table class="kt-table table-auto w-full text-sm">
              <thead>
                <tr class="border-b border-border/40">
                  <th class="py-3 px-4 text-left font-semibold text-secondary-foreground">Référence</th>
                  <th class="py-3 px-4 text-left font-semibold text-secondary-foreground">Date de Création</th>
                  <th class="py-3 px-4 text-left font-semibold text-secondary-foreground">Colis</th>
                  <th class="py-3 px-4 text-center font-semibold text-secondary-foreground">Statut</th>
                </tr>
              </thead>
              <tbody>
                {% for bon in recentBons %}
                  {% set statusLabel = bon.status == 'enregistre' ? 'Enregistré' : (bon.status == 'annule' ? 'Annulé' : 'Brouillon') %}
                  {% set statusBadgeClass = bon.status == 'enregistre' ? 'kt-badge-success' : (bon.status == 'annule' ? 'kt-badge-destructive' : 'kt-badge-warning') %}
                  <tr class="border-b border-border/20 hover:bg-muted/30">
                    <td class="py-3 px-4 font-medium text-foreground">{{ bon.reference ?: 'Brouillon' }}</td>
                    <td class="py-3 px-4 text-foreground font-normal">{{ bon.createdAt ? bon.createdAt|date('d/m/Y H:i') : '-' }}</td>
                    <td class="py-3 px-4 text-foreground font-normal">{{ bon.colis|length }} colis</td>
                    <td class="py-3 px-4 text-center">
                      <span class="kt-badge {{ statusBadgeClass }} kt-badge-outline rounded-[30px] px-2 py-0.5">
                        {{ statusLabel }}
                      </span>
                    </td>
                  </tr>
                {% else %}
                  <tr>
                    <td colspan="4" class="py-8 text-center text-secondary-foreground">Aucun bon de livraison disponible</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
  document.addEventListener("DOMContentLoaded", function() {
    // 1. Daily Volume Chart
    var volumeOptions = {
        series: [{
            name: 'Colis enregistrés',
            data: {{ chartData|json_encode }}
        }],
        chart: {
            type: 'area',
            height: 280,
            toolbar: { show: false },
            zoom: { enabled: false },
            fontFamily: 'Inter, system-ui, sans-serif'
        },
        colors: ['#3e97ff'],
        dataLabels: { enabled: false },
        stroke: { curve: 'smooth', width: 3 },
        fill: {
            type: 'gradient',
            gradient: {
                shadeIntensity: 1,
                opacityFrom: 0.45,
                opacityTo: 0.05,
                stops: [0, 100]
            }
        },
        xaxis: {
            categories: {{ chartLabels|json_encode }},
            axisBorder: { show: false },
            axisTicks: { show: false }
        },
        grid: {
            borderColor: 'rgba(0,0,0,0.05)',
            strokeDashArray: 4
        },
        tooltip: {
            theme: 'light'
        }
    };
    var volumeChart = new ApexCharts(document.querySelector("#volume_chart"), volumeOptions);
    volumeChart.render();

    // 2. State Breakdown Donut Chart
    var stateOptions = {
        series: [
            {{ colisCrees }},
            {{ colisEnPreparation }},
            {{ colisExpedies }},
            {{ colisLivres }},
            {{ colisRetournes }}
        ],
        chart: {
            type: 'donut',
            height: 320,
            fontFamily: 'Inter, system-ui, sans-serif'
        },
        labels: ['Créé', 'En préparation', 'Expédié', 'Livré', 'Retourné'],
        colors: ['#3e97ff', '#ffc700', '#7239ea', '#50cd89', '#f1416c'],
        stroke: { show: false },
        legend: {
            position: 'bottom',
            fontSize: '13px'
        },
        dataLabels: {
            enabled: true,
            formatter: function (val) {
                return parseInt(val) + "%"
            }
        },
        plotOptions: {
            pie: {
                donut: {
                    size: '70%',
                    labels: {
                        show: true,
                        total: {
                            show: true,
                            label: 'Total Colis',
                            formatter: function (w) {
                                return {{ totalColis }}
                            }
                        }
                    }
                }
            }
        }
    };
    var stateChart = new ApexCharts(document.querySelector("#state_chart"), stateOptions);
    stateChart.render();
  });
</script>
{% endblock %}
