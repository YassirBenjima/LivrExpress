{% extends 'base_dashboard.html.twig' %}

{% block title %}Planification des ramassages - LivrExpress{% endblock %}

{% block body %}
<main class="grow pt-5 dashboard-content-shift" id="content" role="content">
    <!-- Container -->
    <div class="kt-container-fixed" id="contentContainer">
    </div>
    <!-- End of Container -->
    <!-- Container — Header -->
    <div class="kt-container-fixed">
     <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
      <div class="flex flex-col justify-center gap-2">
       <h1 class="text-xl font-medium leading-none text-mono">
        Planification des ramassages
       </h1>
       <div class="flex items-center gap-2 text-sm font-normal text-secondary-foreground">
        Vue d'ensemble de vos demandes de ramassage
       </div>
      </div>
      <div class="flex items-center gap-2.5">
       <a class="kt-btn kt-btn-outline" href="{{ path('app_ramassage_index') }}">
        Voir la liste
       </a>
       <a class="kt-btn kt-btn-primary" href="{{ path('app_ramassage_new') }}">
        Nouvelle demande
       </a>
      </div>
     </div>
    </div>
    <!-- End of Container -->

    <!-- Container — KPI Stats -->
    <div class="kt-container-fixed">
     <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-7.5 pb-7.5">
      <!-- Total -->
      <div class="kt-card">
       <div class="kt-card-content flex items-center gap-4 p-5">
        <div class="size-[50px] shrink-0 rounded-xl bg-primary/10 flex items-center justify-center">
         <i class="ki-filled ki-parcel text-xl text-primary"></i>
        </div>
        <div class="flex flex-col">
         <span class="text-2xl font-semibold text-mono">{{ stats.total }}</span>
         <span class="text-xs text-secondary-foreground font-medium">Total demandes</span>
        </div>
       </div>
      </div>
      <!-- En attente -->
      <div class="kt-card">
       <div class="kt-card-content flex items-center gap-4 p-5">
        <div class="size-[50px] shrink-0 rounded-xl bg-primary/10 flex items-center justify-center">
         <i class="ki-filled ki-time text-xl text-primary"></i>
        </div>
        <div class="flex flex-col">
         <span class="text-2xl font-semibold text-mono">{{ stats.pending }}</span>
         <span class="text-xs text-secondary-foreground font-medium">En attente</span>
        </div>
       </div>
      </div>
      <!-- Confirmés -->
      <div class="kt-card">
       <div class="kt-card-content flex items-center gap-4 p-5">
        <div class="size-[50px] shrink-0 rounded-xl bg-primary/10 flex items-center justify-center">
         <i class="ki-filled ki-check-circle text-xl text-primary"></i>
        </div>
        <div class="flex flex-col">
         <span class="text-2xl font-semibold text-mono">{{ stats.confirmed }}</span>
         <span class="text-xs text-secondary-foreground font-medium">Confirmés</span>
        </div>
       </div>
      </div>
      <!-- Ramassés -->
      <div class="kt-card">
       <div class="kt-card-content flex items-center gap-4 p-5">
        <div class="size-[50px] shrink-0 rounded-xl bg-primary/10 flex items-center justify-center">
         <i class="ki-filled ki-courier text-xl text-primary"></i>
        </div>
        <div class="flex flex-col">
         <span class="text-2xl font-semibold text-mono">{{ stats.picked_up }}</span>
         <span class="text-xs text-secondary-foreground font-medium">Ramassés</span>
        </div>
       </div>
      </div>
     </div>
    </div>
    <!-- End of Container -->

    <!-- Container — Calendar -->
    <div class="kt-container-fixed">
        <div class="kt-card">
            <div class="kt-card-header">
                <h3 class="kt-card-title text-mono">Vue Calendrier</h3>
                <div class="kt-card-toolbar">
                    <button class="kt-btn kt-btn-light-primary kt-btn-sm" id="calendar_refresh_btn">
                        <i class="ki-filled ki-arrows-circle text-md"></i>
                        Actualiser
                    </button>
                </div>
            </div>
            <div class="kt-card-body p-5">
                <div id="kt_calendar_app" 
                     data-events-url="{{ path('app_ramassage_calendar_events') }}" 
                     data-new-url="{{ path('app_ramassage_new') }}">
                </div>
            </div>
        </div>
    </div>
    <!-- End of Container -->
   </main>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('assets/css/ramassage-planning.css') }}" rel="stylesheet" type="text/css" />
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/vendors/fullcalendar/index.global.min.js') }}"></script>
    <script src="{{ asset('assets/js/ramassage-planning.js') }}"></script>
{% endblock %}
