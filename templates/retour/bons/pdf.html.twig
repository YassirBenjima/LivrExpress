<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <title>Bon de retour {{ demande.bonReference }}</title>
  <style>
    @page { margin: 18mm 16mm; }
    * { box-sizing: border-box; }
    body {
      font-family: DejaVu Sans, Arial, sans-serif;
      color: #111827;
      font-size: 11pt;
      line-height: 1.45;
    }
    .header {
      border-bottom: 2px solid #1b84ff;
      padding-bottom: 12px;
      margin-bottom: 22px;
    }
    .brand-row { width: 100%; margin-bottom: 10px; }
    .brand-row td { vertical-align: middle; }
    .logo { max-height: 28px; max-width: 160px; }
    .brand-name {
      font-size: 20pt;
      font-weight: 700;
      color: #1b84ff;
      text-align: right;
    }
    .doc-title { font-size: 16pt; font-weight: 700; margin: 0 0 4px 0; }
    .doc-ref { font-size: 12pt; color: #4b5563; margin: 0; }
    .meta-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 22px;
    }
    .meta-table th,
    .meta-table td {
      border: 1px solid #e5e7eb;
      padding: 8px 10px;
      text-align: left;
    }
    .meta-table th {
      width: 34%;
      background: #f9fafb;
      color: #374151;
      font-weight: 600;
    }
    .section-title {
      font-size: 12pt;
      font-weight: 700;
      margin: 0 0 10px 0;
    }
    .colis-table { width: 100%; border-collapse: collapse; }
    .colis-table th,
    .colis-table td {
      border: 1px solid #e5e7eb;
      padding: 8px 10px;
      text-align: left;
    }
    .colis-table th {
      background: #1b84ff;
      color: #ffffff;
      font-weight: 600;
    }
    .colis-table tr:nth-child(even) td { background: #f9fafb; }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 9pt;
      font-weight: 600;
      color: #047857;
      background: #d1fae5;
      border: 1px solid #6ee7b7;
    }
    .footer {
      margin-top: 28px;
      padding-top: 10px;
      border-top: 1px solid #e5e7eb;
      font-size: 9pt;
      color: #6b7280;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="header">
    <table class="brand-row">
      <tr>
        <td>
          {% if logo_data_uri %}
            <img class="logo" alt="LivrExpress" src="{{ logo_data_uri }}"/>
          {% else %}
            <span class="brand-name" style="text-align:left;">LivrExpress</span>
          {% endif %}
        </td>
        <td class="brand-name">Bon de Retour</td>
      </tr>
    </table>
    <p class="doc-title">Bon de retour</p>
    <p class="doc-ref">Référence : {{ demande.bonReference }}</p>
  </div>

  <table class="meta-table">
    <tr>
      <th>Réf</th>
      <td>{{ demande.bonReference }}</td>
    </tr>
    <tr>
      <th>Date de création</th>
      <td>{{ demande.createdAt ? demande.createdAt|date('d/m/Y H:i') : '-' }}</td>
    </tr>
    <tr>
      <th>Date de réception</th>
      <td>{{ demande.receivedAt ? demande.receivedAt|date('d/m/Y H:i') : '-' }}</td>
    </tr>
    <tr>
      <th>Réception colis</th>
      <td>{{ demande.receptionType }}</td>
    </tr>
    <tr>
      <th>Statut</th>
      <td>{{ status_label }}</td>
    </tr>
    {% if demande.note %}
      <tr>
        <th>Note &amp; Remarque</th>
        <td>{{ demande.note }}</td>
      </tr>
    {% endif %}
  </table>

  <p class="section-title">Colis</p>
  <table class="colis-table">
    <thead>
      <tr>
        <th style="width: 48px;">#</th>
        <th>Code de suivi</th>
        <th>Nature du produit</th>
        <th>Ville</th>
      </tr>
    </thead>
    <tbody>
      {% for colis in demande.colis %}
        <tr>
          <td>{{ loop.index }}</td>
          <td><span class="badge">{{ colis.trackingCode }}</span></td>
          <td>{{ colis.productNature }}</td>
          <td>{{ colis.city }}</td>
        </tr>
      {% else %}
        <tr>
          <td colspan="4">Aucun colis associé.</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  <div class="footer">
    Document généré par LivrExpress — {{ 'now'|date('d/m/Y H:i') }}
  </div>
</body>
</html>
