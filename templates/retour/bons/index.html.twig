{% extends 'base_dashboard.html.twig' %}

{% block title %}Liste des bons de retour - LivrExpress{% endblock %}

{% block body %}
{% set totalBons = bons|length %}
<main class="grow pt-5 dashboard-content-shift" id="content" role="content">
  <div class="kt-container-fixed" id="contentContainer"></div>

  <div class="kt-container-fixed">
    <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
      <div class="flex flex-col justify-center gap-2">
        <h1 class="text-xl font-medium leading-none text-mono">
          Liste des bons de retour
        </h1>
        <div class="flex items-center flex-wrap gap-1.5 font-medium">
          <span class="text-base text-secondary-foreground">Total bons :</span>
          <span class="text-base text-foreground font-medium">{{ totalBons }}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="kt-container-fixed">
    <div class="grid gap-5 lg:gap-7.5">
      <div class="kt-card kt-card-grid min-w-full">
        <div class="kt-card-header flex-wrap gap-2">
          <h3 class="kt-card-title text-sm">
            Affichage de {{ totalBons }} bon(s) de retour
          </h3>
          <form class="flex flex-wrap gap-2 lg:gap-5" method="get" action="{{ path('app_retour_bons_index') }}">
            <div class="flex">
              <label class="kt-input">
                <i class="ki-filled ki-magnifier"></i>
                <input data-kt-datatable-search="#retour_bons_table" name="q" placeholder="Référence, code de suivi..." type="text" value="{{ search_query|default('') }}"/>
              </label>
            </div>
            <div class="flex flex-wrap gap-2.5">
              <select class="kt-select w-36" data-kt-select="true" data-kt-select-placeholder="Statut" name="statut">
                <option value="">Tous les statuts</option>
                {% for statut in statuts_possibles %}
                  <option value="{{ statut }}" {{ selected_statut|default('') == statut ? 'selected' : '' }}>
                    {{ statut_labels[statut]|default(statut) }}
                  </option>
                {% endfor %}
              </select>
              <button class="kt-btn kt-btn-outline kt-btn-primary" type="submit">
                <i class="ki-filled ki-setting-4"></i>
                Filtrer
              </button>
              <a class="kt-btn kt-btn-outline" href="{{ path('app_retour_bons_index') }}">
                Réinitialiser
              </a>
            </div>
          </form>
        </div>

        <div class="kt-card-content">
          <div data-kt-datatable="true" data-kt-datatable-state-save="false" id="retour_bons_table">
            <div class="kt-scrollable-x-auto">
              <table class="kt-table table-auto kt-table-border" data-kt-datatable-table="true">
                <thead>
                  <tr>
                    <th class="min-w-[180px]">
                      <span class="kt-table-col">
                        <span class="kt-table-col-label">Réf</span>
                        <span class="kt-table-col-sort"></span>
                      </span>
                    </th>
                    <th class="min-w-[160px]">
                      <span class="kt-table-col">
                        <span class="kt-table-col-label">Date de création</span>
                        <span class="kt-table-col-sort"></span>
                      </span>
                    </th>
                    <th class="min-w-[170px]">
                      <span class="kt-table-col">
                        <span class="kt-table-col-label">Date de réception</span>
                        <span class="kt-table-col-sort"></span>
                      </span>
                    </th>
                    <th class="min-w-[130px]">
                      <span class="kt-table-col">
                        <span class="kt-table-col-label">Statut</span>
                        <span class="kt-table-col-sort"></span>
                      </span>
                    </th>
                    <th class="min-w-[220px]">
                      <span class="kt-table-col">
                        <span class="kt-table-col-label">Colis</span>
                        <span class="kt-table-col-sort"></span>
                      </span>
                    </th>
                    <th class="min-w-[120px] text-center">
                      <span class="kt-table-col">
                        <span class="kt-table-col-label">Actions</span>
                      </span>
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {% for bon in bons %}
                    {% set statusLabel = statut_labels[bon.status]|default(bon.status) %}
                    {% set statusBadgeClass = 'kt-badge-warning' %}
                    {% if bon.status == 'processing' %}
                      {% set statusBadgeClass = 'kt-badge-info' %}
                    {% elseif bon.status == 'received' %}
                      {% set statusBadgeClass = 'kt-badge-success' %}
                    {% elseif bon.status == 'cancelled' %}
                      {% set statusBadgeClass = 'kt-badge-destructive' %}
                    {% endif %}
                    <tr>
                      <td class="text-foreground font-medium">
                        {{ bon.bonReference }}
                      </td>
                      <td class="text-foreground font-normal">
                        {{ bon.createdAt ? bon.createdAt|date('d/m/Y H:i') : '-' }}
                      </td>
                      <td class="text-foreground font-normal">
                        {{ bon.receivedAt ? bon.receivedAt|date('d/m/Y H:i') : '-' }}
                      </td>
                      <td>
                        <span class="kt-badge {{ statusBadgeClass }} kt-badge-outline rounded-[30px]">
                          <span class="kt-badge-dot size-1.5"></span>
                          {{ statusLabel }}
                        </span>
                      </td>
                      <td>
                        <div class="flex flex-wrap gap-1.5">
                          {% for colis in bon.colis %}
                            <span class="kt-badge kt-badge-primary kt-badge-outline rounded-[30px]">
                              {{ colis.trackingCode }}
                            </span>
                          {% else %}
                            <span class="text-secondary-foreground">-</span>
                          {% endfor %}
                        </div>
                      </td>
                      <td class="text-center">
                        <div class="kt-menu flex-inline" data-kt-menu="true">
                          <div class="kt-menu-item" data-kt-menu-item-offset="0, 10px" data-kt-menu-item-placement="bottom-end" data-kt-menu-item-placement-rtl="bottom-start" data-kt-menu-item-toggle="dropdown" data-kt-menu-item-trigger="click">
                            <button class="kt-menu-toggle kt-btn kt-btn-sm kt-btn-icon kt-btn-ghost">
                              <i class="ki-filled ki-dots-vertical text-lg"></i>
                            </button>
                            <div class="kt-menu-dropdown kt-menu-default w-full max-w-[175px]" data-kt-menu-dismiss="true">
                              <div class="kt-menu-item">
                                <a
                                  class="kt-menu-link"
                                  href="{{ path('app_retour_bons_download', { id: bon.id }) }}"
                                  data-bon-retour-download="true"
                                  data-can-download="{{ bon.bonReference ? '1' : '0' }}"
                                  data-filename="{{ bon.bonReference ? (bon.bonReference ~ '.pdf')|e('html_attr') : 'bon-retour.pdf' }}"
                                >
                                  <span class="kt-menu-icon"><i class="ki-filled ki-file-down"></i></span>
                                  <span class="kt-menu-title">Télécharger</span>
                                </a>
                              </div>
                            </div>
                          </div>
                        </div>
                      </td>
                    </tr>
                  {% else %}
                    <tr>
                      <td colspan="6" class="text-secondary-foreground text-center py-8">
                        Aucun bon de retour trouvé.
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>

            <div class="kt-card-footer justify-center md:justify-between flex-col md:flex-row gap-5 text-secondary-foreground text-sm font-medium">
              <div class="flex items-center gap-2 order-2 md:order-1">
                Afficher
                <select class="kt-select w-16" data-kt-datatable-size="true" data-kt-select="" name="perpage"></select>
                par page
              </div>
              <div class="flex items-center gap-4 order-1 md:order-2">
                <span data-kt-datatable-info="true"></span>
                <div class="kt-datatable-pagination" data-kt-datatable-pagination="true"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="{{ asset('assets/js/retour-bons.js?v=1') }}"></script>
{% endblock %}
