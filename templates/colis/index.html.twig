{% extends 'base_dashboard.html.twig' %}

{% block title %}Liste des colis - LivrExpress{% endblock %}

{% block body %}
{% set totalColis = colis_list|length %}
{% set totalMontant = 0 %}
{% for colis in colis_list %}
    {% set prixNet = colis.price|replace({',': '.', ' ': '', 'DH': '', 'MAD': ''}) %}
    {% set totalMontant = totalMontant + (prixNet + 0) %}
{% endfor %}
<main class="grow pt-5 dashboard-content-shift" id="content" role="content">
    <!-- Container -->
    <div class="kt-container-fixed" id="contentContainer">
    </div>
    <!-- End of Container -->
    <!-- Container -->
    <div class="kt-container-fixed">
     <div class="flex flex-wrap items-center lg:items-end justify-between gap-5 pb-7.5">
      <div class="flex flex-col justify-center gap-2">
       <h1 class="text-xl font-medium leading-none text-mono">
        Liste des Colis
       </h1>
       <div class="flex items-center flex-wrap gap-1.5 font-medium">
        <span class="text-base text-secondary-foreground">
         Total colis:
        </span>
        <span class="text-base text-foreground font-medium me-2">
         {{ totalColis }}
        </span>
        <span class="text-base text-secondary-foreground">
         Montant total:
        </span>
        <span class="text-base text-foreground font-medium">
         {{ totalMontant|number_format(2, ',', ' ') }} MAD
        </span>
       </div>
      </div>
      <div class="flex items-center gap-2.5">
       <a class="kt-btn kt-btn-outline" href="#">
        Import CSV
       </a>
       <a class="kt-btn kt-btn-primary" href="{{ path('app_colis_new') }}">
        Ajouter un colis
       </a>
      </div>
     </div>
    </div>
    <!-- End of Container -->
    <!-- Container -->
    <div class="kt-container-fixed">
     <div class="grid gap-5 lg:gap-7.5">
      <div class="kt-card kt-card-grid min-w-full">
       <div class="kt-card-header flex-wrap gap-2">
        <h3 class="kt-card-title text-sm">
         Affichage de {{ totalColis }} colis
        </h3>
        <div class="flex flex-wrap gap-2 lg:gap-5">
         <div class="flex">
          <label class="kt-input">
           <i class="ki-filled ki-magnifier">
           </i>
           <input data-kt-datatable-search="#team_crew_table" placeholder="Search users" type="text" value=""/>
          </label>
         </div>
         <div class="flex flex-wrap gap-2.5">
          <select class="kt-select w-36" data-kt-select="true" data-kt-select-placeholder="Select a status">
           <option value="1">
            Active
           </option>
           <option value="2">
            Disabled
           </option>
           <option value="2">
            Pending
           </option>
          </select>
          <select class="kt-select w-36" data-kt-select="true" data-kt-select-placeholder="Select a sort">
           <option value="1">
            Latest
           </option>
           <option value="2">
            Older
           </option>
           <option value="3">
            Oldest
           </option>
          </select>
          <button class="kt-btn kt-btn-outline kt-btn-primary">
           <i class="ki-filled ki-setting-4">
           </i>
           Filters
          </button>
         </div>
        </div>
       </div>
       <div class="kt-card-content">
        <div data-kt-datatable="true" data-kt-datatable-state-save="false" id="team_crew_table">
         <div class="kt-scrollable-x-auto">
          <table class="kt-table table-auto kt-table-border" data-kt-datatable-table="true">
           <thead>
            <tr>
             <th class="min-w-[150px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Code Suivi
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[180px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Nom du produit
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[150px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Date de création
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[150px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Destinataire
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[120px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                État
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[120px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Statut
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[120px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Livreur
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[160px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Date de livraison
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[140px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Ville
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[120px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Prix
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="min-w-[140px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Réclamation
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="w-[90px] text-center">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Actions
               </span>
              </span>
             </th>
             <th class="min-w-[180px]">
              <span class="kt-table-col">
               <span class="kt-table-col-label">
                Comments
               </span>
               <span class="kt-table-col-sort">
               </span>
              </span>
             </th>
             <th class="w-[60px]">
             </th>
            </tr>
           </thead>
           <tbody>
            {% for colis in colis_list %}
             <tr>
              <td class="text-foreground font-medium">
               {{ colis.orderNumber }}
              </td>
              <td class="text-foreground font-normal">
               {{ colis.productNature }}
              </td>
              <td class="text-foreground font-normal">
               {{ colis.createdAt ? colis.createdAt|date('d/m/Y H:i') : '-' }}
              </td>
              <td class="text-foreground font-normal">
               {{ colis.address }}
              </td>
              <td>
               <span class="kt-badge kt-badge-outline rounded-[30px]">
                <span class="kt-badge-dot size-1.5">
                </span>
                Cree
               </span>
              </td>
              <td class="text-foreground font-normal">
               En attente
              </td>
              <td class="text-foreground font-normal">
               -
              </td>
              <td class="text-foreground font-normal">
               -
              </td>
              <td class="text-foreground font-normal">
               {{ colis.city }}
              </td>
              <td class="text-foreground font-medium">
               {{ colis.price|number_format(2, ',', ' ') }} MAD
              </td>
              <td class="text-foreground font-normal">
               Non
              </td>
              <td class="text-center">
               <div class="kt-menu flex-inline" data-kt-menu="true">
                <div class="kt-menu-item" data-kt-menu-item-offset="0, 10px" data-kt-menu-item-placement="bottom-end" data-kt-menu-item-placement-rtl="bottom-start" data-kt-menu-item-toggle="dropdown" data-kt-menu-item-trigger="click">
                 <button class="kt-menu-toggle kt-btn kt-btn-sm kt-btn-icon kt-btn-ghost">
                  <i class="ki-filled ki-dots-vertical text-lg">
                  </i>
                 </button>
                 <div class="kt-menu-dropdown kt-menu-default w-full max-w-[175px]" data-kt-menu-dismiss="true">
                  <div class="kt-menu-item">
                   <a class="kt-menu-link" href="#">
                    <span class="kt-menu-icon">
                     <i class="ki-filled ki-search-list">
                     </i>
                    </span>
                    <span class="kt-menu-title">
                     Voir
                    </span>
                   </a>
                  </div>
                  <div class="kt-menu-item">
                   <a class="kt-menu-link" href="#">
                    <span class="kt-menu-icon">
                     <i class="ki-filled ki-pencil">
                     </i>
                    </span>
                    <span class="kt-menu-title">
                     Modifier
                    </span>
                   </a>
                  </div>
                  <div class="kt-menu-separator">
                  </div>
                  <div class="kt-menu-item">
                   <a class="kt-menu-link" href="#">
                    <span class="kt-menu-icon">
                     <i class="ki-filled ki-trash">
                     </i>
                    </span>
                    <span class="kt-menu-title">
                     Supprimer
                    </span>
                   </a>
                  </div>
                 </div>
                </div>
               </div>
              </td>
              <td class="text-foreground font-normal">
               {{ colis.comment ?: '-' }}
              </td>
             </tr>
            {% endfor %}
           </tbody>
          </table>
         </div>
         <div class="kt-card-footer justify-center md:justify-between flex-col md:flex-row gap-5 text-secondary-foreground text-sm font-medium">
          <div class="flex items-center gap-2 order-2 md:order-1">
           Show
           <select class="kt-select w-16" data-kt-datatable-size="true" data-kt-select="" name="perpage">
           </select>
           per page
          </div>
          <div class="flex items-center gap-4 order-1 md:order-2">
           <span data-kt-datatable-info="true">
           </span>
           <div class="kt-datatable-pagination" data-kt-datatable-pagination="true">
           </div>
          </div>
         </div>
        </div>
       </div>
      </div>

     </div>
    </div>
    <!-- End of Container -->
   </main>
{% endblock %}
