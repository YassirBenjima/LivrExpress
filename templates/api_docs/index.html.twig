{% block javascripts %}
  {{ parent() }}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const tabs = document.querySelectorAll('.api-tab-btn');
      const contents = document.querySelectorAll('.api-tab-content');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Remove active class from all tabs
          tabs.forEach(t => {
            t.classList.remove('active');
            t.classList.add('text-secondary-foreground');
            t.classList.remove('text-primary');
          });
          
          // Add active class to clicked tab
          tab.classList.add('active');
          tab.classList.remove('text-secondary-foreground');
          tab.classList.add('text-primary');

          // Hide all tab contents
          contents.forEach(content => {
            content.classList.remove('active');
          });

          // Show targeted tab content
          const target = tab.getAttribute('data-tab');
          document.getElementById('tab_' + target).classList.add('active');
        });
      });
    });

    function copyToClipboard(text, btn) {
      navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="ki-filled ki-check"></i> Copié !';
        btn.disabled = true;
        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.disabled = false;
        }, 2000);
      });
    }
  </script>
{% endblock %}
